CREATE TABLE CONTINENTES (
    ID_CONTINENTE NUMBER PRIMARY KEY,
    NOME VARCHAR2(50) NOT NULL
);

CREATE TABLE PAISES (
    ID_PAIS NUMBER PRIMARY KEY,
    NOME VARCHAR2(100) NOT NULL,
    CAPITAL VARCHAR2(100),
    MOEDA VARCHAR2(50),
    ID_CONTINENTE NUMBER,
    CONSTRAINT FK_PAIS_CONTINENTE
        FOREIGN KEY (ID_CONTINENTE)
        REFERENCES CONTINENTES(ID_CONTINENTE)
);

CREATE TABLE CIDADES (
    ID_CIDADE NUMBER PRIMARY KEY,
    NOME VARCHAR2(100),
    ESTADO_PROVINCIA VARCHAR2(100),
    POPULACAO NUMBER,
    ID_PAIS NUMBER,
    CONSTRAINT FK_CIDADE_PAIS
        FOREIGN KEY (ID_PAIS)
        REFERENCES PAISES(ID_PAIS)
);

CREATE TABLE SETORES (
    ID_SETOR NUMBER PRIMARY KEY,
    NOME VARCHAR2(100),
    DESCRICAO VARCHAR2(300)
);

CREATE TABLE EMPRESAS (
    ID_EMPRESA NUMBER PRIMARY KEY,
    NOME VARCHAR2(200),
    ANO_FUNDACAO NUMBER,
    FUNDADOR VARCHAR2(200),
    STATUS VARCHAR2(30),
    FUNCIONARIOS NUMBER,
    SITE VARCHAR2(200),
    DESCRICAO VARCHAR2(1000),
    ID_CIDADE NUMBER,
    ID_SETOR NUMBER,

    CONSTRAINT FK_EMPRESA_CIDADE
        FOREIGN KEY (ID_CIDADE)
        REFERENCES CIDADES(ID_CIDADE),

    CONSTRAINT FK_EMPRESA_SETOR
        FOREIGN KEY (ID_SETOR)
        REFERENCES SETORES(ID_SETOR)
);

CREATE TABLE PREMIOS (
    ID_PREMIO NUMBER PRIMARY KEY,
    NOME VARCHAR2(200),
    ANO NUMBER,
    ORGANIZACAO VARCHAR2(200)
);

CREATE TABLE EMPRESA_PREMIO (
    ID_EMPRESA NUMBER,
    ID_PREMIO NUMBER,

    PRIMARY KEY(ID_EMPRESA, ID_PREMIO),

    FOREIGN KEY(ID_EMPRESA)
        REFERENCES EMPRESAS(ID_EMPRESA),

    FOREIGN KEY(ID_PREMIO)
        REFERENCES PREMIOS(ID_PREMIO)
);

CREATE TABLE PRODUTOS_SERVICOS (
    ID_PRODUTO NUMBER PRIMARY KEY,
    NOME VARCHAR2(150),
    TIPO VARCHAR2(50),
    ID_EMPRESA NUMBER,

    FOREIGN KEY(ID_EMPRESA)
        REFERENCES EMPRESAS(ID_EMPRESA)
);
